{
  "name": "option-strategy-engine-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "test:update-golden": "UPDATE_GOLDEN=1 node --import tsx --test test/*.test.ts",
    "check": "./node_modules/.bin/tsc --noEmit && node --import tsx --test test/*.test.ts",
    "start": "unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY all_proxy && node dist/index.js",
    "dev": "unset HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY all_proxy && nodemon --quiet --delay 400ms --watch src --ext ts --exec \"tsc && node dist/index.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0"
  }
}
