# Copy to .env and fill in.
PORT=3001

# MarketData.app — default for Live mode. Free tier = 100 options requests/day.
MARKETDATA_TOKEN=
MARKETDATA_BASE=https://api.marketdata.app

# Live VIX/SPX for dashboard + narrative (Finnhub /quote only). Unset key = silent skip, static mock macro. LIVE_MACRO=0 forces skip.
# LIVE_MACRO=0

# DeepSeek — used for AI commentary (Dashboard / Strategy / Positions narrative)
# OpenAI-compatible API, much cheaper than Claude. https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE=https://api.deepseek.com

# Finnhub — earnings calendar, SPY/VIXY quotes, symbol search (自选 ⌘K)
# Free tier = 60 calls/min. https://finnhub.io/register
FINNHUB_API_KEY=
FINNHUB_BASE=https://finnhub.io

# Recommendation feedback loop (gitignored under cache/recommendations/)
# FEEDBACK_RECORD=0          # set to 0 to disable writing snapshots when dashboard builds
# FEEDBACK_AUTO_HYDRATE=1    # with daily cron: fill outcomes for snapshots past FEEDBACK_HORIZON_DAYS
# FEEDBACK_HORIZON_DAYS=5   # calendar days after etDay before hydrate runs

# Optional fallbacks (currently unused):
# POLYGON_API_KEY=
# YAHOO_BASE=https://query1.finance.yahoo.com
# TRADIER_TOKEN=
